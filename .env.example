# ──────────────────────────────────────────────
# Email (for contact form — using Nodemailer)
# ──────────────────────────────────────────────
# Create a Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# The address where you want to receive contact form submissions
EMAIL_TO=your_gmail@gmail.com

# ──────────────────────────────────────────────
# Site metadata (used in og tags / SEO)
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
